# =====================================================================
#  환경변수 예시 — 실제 값은 .env.local(커밋 금지)에 채우고,
#  배포(Vercel) 시에는 Vercel → Project → Settings → Environment Variables 에 등록한다.
#  (정리: doc/13_vercel_deployment.md / 레지스트리: doc/10_env_config_registry.md)
# =====================================================================

# --- Supabase (Step 3) ---------------------------------------------
# Supabase 프로젝트 → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 서버 전용(절대 클라이언트 노출/커밋 금지). 런타임 시크릿으로 관리 권장.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Google 로그인 (Supabase OAuth) --------------------------------
# ※ Google Client ID/Secret은 '앱 env'가 아니라 'Supabase 대시보드'에 등록합니다.
#   1) Google Cloud Console → API/서비스 → 사용자 인증 정보 → OAuth 클라이언트 ID(웹) 생성
#      · 승인된 리디렉션 URI 에 Supabase 콜백 추가:
#        https://ofxzkwbqwpsjoeqjhrpl.supabase.co/auth/v1/callback
#   2) Supabase → Authentication → Providers → Google → 활성화 후
#      위 Client ID / Client Secret 입력
#   3) Supabase → Authentication → URL Configuration:
#      · Site URL: 배포 도메인(예: https://vibe.habitree.io)
#      · Redirect URLs 에 추가: http://localhost:3000/auth/callback , https://vibe.habitree.io/auth/callback
#   → 앱은 NEXT_PUBLIC_SUPABASE_URL/ANON_KEY 만 있으면 됨(Google 키는 위 Supabase에 저장).

# --- 사이트 ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Polar 응원 키트 결제 (/support, /api/donate) -----------------------
# ⚠️ Polar는 '기부/후원'을 허용하지 않음 → 반드시 "디지털 상품"으로 등록.
# Polar 대시보드 → Products → New Product 로 "응원 키트(Cheer Kit)" 생성:
#   · 유형: Digital product (다운로드 파일 benefit 첨부 — 예: 감사 카드 PDF·바이브코딩
#           체크리스트·배경화면 팩 등 실제 디지털 파일을 1개 이상 업로드)
#   · 가격: "Pay what you want"(금액 자유) → 구매자가 금액 선택
#   · 생성된 Product ID 를 POLAR_PRODUCT_ID 에 입력
# Access Token: Settings → Developers → New Token (서버 전용).
POLAR_ACCESS_TOKEN=YOUR-POLAR-ORG-ACCESS-TOKEN
POLAR_PRODUCT_ID=YOUR-POLAR-CHEER-KIT-PRODUCT-ID
# 결제 서버: sandbox(테스트) 또는 production(실거래). 기본 production.
POLAR_SERVER=sandbox

# --- AI 챗봇 (OpenAI, /api/chat) -----------------------------------
# platform.openai.com → API keys 에서 발급(서버 전용·커밋 금지).
OPENAI_API_KEY=YOUR-OPENAI-API-KEY
# ※ 모델 / temperature / 기본지침은 환경변수가 아니라 DB(public.chat_settings)에 저장한다.
#   관리자가 /admin/settings 에서 저장하면 재배포 없이 즉시 반영된다. 기본값 gpt-4o-mini.

# --- 관리자 -----------------------------------------------------------
# 참고용 표기. 실제 권한 판별은 profiles.role='admin' (DB)로 한다.
ADMIN_EMAIL=you@example.com
