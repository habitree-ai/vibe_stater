# =====================================================================
#  환경변수 예시 — 실제 값은 .env.local(커밋 금지)에 채우고,
#  배포 시에는 Cloudflare Workers Builds의 Variables and secrets에 등록한다.
#  (doc/07_github_cloudflare_deploy.md 4장 / doc/00_setup_guide.md)
# =====================================================================

# --- Supabase (Step 3) ---------------------------------------------
# Supabase 프로젝트 → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 서버 전용(절대 클라이언트 노출/커밋 금지). 런타임 시크릿으로 관리 권장.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- 사이트 ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
