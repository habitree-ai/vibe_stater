# =====================================================================
#  환경변수 예시 — 실제 값은 .env.local(커밋 금지)에 채우고,
#  배포(Vercel) 시에는 Vercel → Project → Settings → Environment Variables 에 등록한다.
#  (정리: doc/13_vercel_deployment.md / 레지스트리: doc/10_env_config_registry.md)
# =====================================================================

# --- Supabase (Step 3) ---------------------------------------------
# Supabase 프로젝트 → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 서버 전용(절대 클라이언트 노출/커밋 금지). 런타임 시크릿으로 관리 권장.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- 사이트 ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Polar 응원 키트 결제 (/support, /api/donate) -----------------------
# ⚠️ Polar는 '기부/후원'을 허용하지 않음 → 반드시 "디지털 상품"으로 등록.
# Polar 대시보드 → Products → New Product 로 "응원 키트(Cheer Kit)" 생성:
#   · 유형: Digital product (다운로드 파일 benefit 첨부 — 예: 감사 카드 PDF·바이브코딩
#           체크리스트·배경화면 팩 등 실제 디지털 파일을 1개 이상 업로드)
#   · 가격: "Pay what you want"(금액 자유) → 구매자가 금액 선택
#   · 생성된 Product ID 를 POLAR_PRODUCT_ID 에 입력
# Access Token: Settings → Developers → New Token (서버 전용).
POLAR_ACCESS_TOKEN=YOUR-POLAR-ORG-ACCESS-TOKEN
POLAR_PRODUCT_ID=YOUR-POLAR-CHEER-KIT-PRODUCT-ID
# 결제 서버: sandbox(테스트) 또는 production(실거래). 기본 production.
POLAR_SERVER=sandbox

# --- AI 챗봇 (Anthropic, /api/chat) --------------------------------
# console.anthropic.com → API Keys 에서 발급(서버 전용·커밋 금지).
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-API-KEY
# (선택) 기본 claude-haiku-4-5. 상위 모델: claude-sonnet-4-6 / claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5
