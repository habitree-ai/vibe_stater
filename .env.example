# =====================================================================
#  환경변수 예시 — 실제 값은 .env.local(커밋 금지)에 채우고,
#  배포 시에는 Cloudflare Workers Builds의 Variables and secrets에 등록한다.
#  (doc/07_github_cloudflare_deploy.md 4장 / doc/00_setup_guide.md)
# =====================================================================

# --- Supabase (Step 3) ---------------------------------------------
# Supabase 프로젝트 → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 서버 전용(절대 클라이언트 노출/커밋 금지). 런타임 시크릿으로 관리 권장.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- 사이트 ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Polar 후원 결제 (/support, /api/donate) -----------------------
# Polar 대시보드 → Settings → API/Tokens 에서 Organization Access Token 발급(서버 전용).
# 후원 상품은 "Pay what you want" 가격으로 생성하고 그 Product ID를 넣는다.
POLAR_ACCESS_TOKEN=YOUR-POLAR-ORG-ACCESS-TOKEN
POLAR_PRODUCT_ID=YOUR-POLAR-DONATION-PRODUCT-ID
# 결제 서버: sandbox(테스트) 또는 production(실거래). 기본 production.
POLAR_SERVER=sandbox

# --- AI 챗봇 (Anthropic, /api/chat) --------------------------------
# console.anthropic.com → API Keys 에서 발급(서버 전용·커밋 금지).
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-API-KEY
# (선택) 기본 claude-haiku-4-5. 상위 모델: claude-sonnet-4-6 / claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5
